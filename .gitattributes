# Default text handling
* text=auto

# Markdown and Quarto documents
*.md text eol=lf
*.qmd text eol=lf

# YAML configuration files
*.yml text eol=lf
*.yaml text eol=lf

# Stata code
*.do text eol=lf
*.ado text eol=lf
*.sthlp text eol=lf

# Python and PowerShell scripts
*.py text eol=lf
*.ps1 text eol=crlf

# Web and style files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.json text eol=lf

# CSV and plain text outputs
*.csv text eol=lf
*.txt text eol=lf

# Images and binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text eol=lf
*.pdf binary
*.zip binary